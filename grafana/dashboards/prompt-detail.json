{
  "uid": "cc-prompt-detail",
  "title": "Claude Code - Prompt Detail",
  "tags": ["claude-code", "prompts", "detail"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "links": [
    { "title": "< Back to Prompt List", "url": "/d/cc-prompt-analytics?${__url_time_range}", "type": "link", "icon": "arrow-left", "targetBlank": false },
    { "title": "Overview", "url": "/d/cc-overview", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Tool Analytics", "url": "/d/cc-tool-analytics", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "annotations": { "list": [] },
  "templating": {
    "list": [
      {
        "name": "prompt_id",
        "label": "Prompt ID",
        "type": "textbox",
        "current": { "value": "", "text": "" },
        "options": [],
        "query": "",
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Prompt Summary",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] },
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Cost",
      "type": "stat",
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap cost_usd [$__range]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "id": 2,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Total Tokens",
      "type": "stat",
      "targets": [{
        "expr": "sum(sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap input_tokens [$__range])) + sum(sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap output_tokens [$__range]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "id": 3,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "API Calls",
      "type": "stat",
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` [$__range]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "id": 4,
      "options": { "colorMode": "value", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "title": "Tool Executions",
      "type": "stat",
      "targets": [{
        "expr": "sum(count_over_time({service_name=\"claude-code\"} | event_name = `tool_result` | prompt_id = `$prompt_id` [$__range]))",
        "instant": true,
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 110,
      "title": "Selected Prompt Content",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": { "defaults": { "custom": { "align": "left" } }, "overrides": [] },
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 6 },
      "id": 11,
      "options": { "showHeader": false, "footer": { "show": false } },
      "title": "Prompt Text",
      "type": "table",
      "targets": [{ "expr": "{service_name=\"claude-code\"} | event_name = `user_prompt` | prompt_id = `$prompt_id`", "refId": "A" }],
      "transformations": [
        { "id": "extractFields", "options": { "source": "labels", "format": "auto" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "Line": true, "id": true, "tsNs": true, "labels": true, "app_version": true, "department": true, "event_name": true, "host_arch": true, "level": true, "observed_timestamp": true, "organization_id": true, "os_type": true, "os_version": true, "scope_name": true, "scope_version": true, "service_name": true, "service_version": true, "session_id": true, "team_id": true, "terminal_type": true, "user_account_id": true, "user_account_uuid": true, "user_email": true, "user_id": true, "__error__": true, "__error_details__": true, "prompt_id": true, "event_sequence": true, "event_timestamp": true, "prompt_length": true }
        }}
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "id": 101,
      "title": "Conversation History",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "left", "filterable": true, "inspect": true }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "event_sequence" },
            "properties": [
              { "id": "custom.width", "value": 50 },
              { "id": "displayName", "value": "#" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "event_timestamp" },
            "properties": [
              { "id": "custom.width", "value": 180 },
              { "id": "displayName", "value": "Time" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "prompt" },
            "properties": [
              { "id": "custom.width", "value": 600 },
              { "id": "displayName", "value": "Prompt" }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "prompt_id" },
            "properties": [
              { "id": "custom.width", "value": 130 },
              { "id": "displayName", "value": "Prompt ID" },
              { "id": "links", "value": [{
                "title": "View this prompt",
                "url": "/d/cc-prompt-detail?var-prompt_id=${__value.text}&${__url_time_range}",
                "targetBlank": false
              }]}
            ]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 11 },
      "id": 5,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "#", "desc": false }],
        "footer": { "show": true, "reducer": ["count"], "countRows": true }
      },
      "title": "Session Conversation (all prompts — current prompt highlighted by Prompt ID column)",
      "type": "table",
      "targets": [{
        "expr": "{service_name=\"claude-code\"} | event_name = `user_prompt`",
        "refId": "A"
      }],
      "transformations": [
        { "id": "extractFields", "options": { "source": "labels", "format": "auto" } },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true, "Line": true, "id": true, "tsNs": true, "labels": true,
              "app_version": true, "department": true, "event_name": true, "host_arch": true,
              "level": true, "observed_timestamp": true, "organization_id": true, "os_type": true,
              "os_version": true, "scope_name": true, "scope_version": true, "service_name": true,
              "service_version": true, "session_id": true, "team_id": true, "terminal_type": true,
              "user_account_id": true, "user_account_uuid": true, "user_email": true, "user_id": true,
              "__error__": true, "__error_details__": true, "prompt_length": true
            },
            "indexByName": { "event_sequence": 0, "event_timestamp": 1, "prompt": 2, "prompt_id": 3 }
          }
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 16 },
      "id": 102,
      "title": "Tool Executions for this Prompt",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "center", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "tool_name" }, "properties": [{ "id": "displayName", "value": "Tool" }, { "id": "custom.width", "value": 140 }] },
          { "matcher": { "id": "byName", "options": "Value #Count" }, "properties": [{ "id": "displayName", "value": "Count" }] },
          { "matcher": { "id": "byName", "options": "Value #AvgDur" }, "properties": [{ "id": "displayName", "value": "Avg Duration" }, { "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "Value #MaxDur" }, "properties": [{ "id": "displayName", "value": "Max Duration" }, { "id": "unit", "value": "ms" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 17 },
      "id": 6,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Count", "desc": true }] },
      "title": "Tool Usage Summary",
      "type": "table",
      "targets": [
        { "expr": "sum by (tool_name) (count_over_time({service_name=\"claude-code\"} | event_name = `tool_result` | prompt_id = `$prompt_id` [$__range]))", "refId": "Count", "instant": true },
        { "expr": "avg by (tool_name) (avg_over_time({service_name=\"claude-code\"} | event_name = `tool_result` | prompt_id = `$prompt_id` | unwrap duration_ms [$__range]))", "refId": "AvgDur", "instant": true },
        { "expr": "max by (tool_name) (max_over_time({service_name=\"claude-code\"} | event_name = `tool_result` | prompt_id = `$prompt_id` | unwrap duration_ms [$__range]))", "refId": "MaxDur", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 17 },
      "id": 7,
      "options": { "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true },
      "title": "Tool Execution Log",
      "type": "logs",
      "targets": [{
        "expr": "{service_name=\"claude-code\"} | event_name = `tool_result` | prompt_id = `$prompt_id`",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 103,
      "title": "API Requests for this Prompt",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "center", "filterable": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "model" }, "properties": [{ "id": "displayName", "value": "Model" }, { "id": "custom.width", "value": 200 }] },
          { "matcher": { "id": "byName", "options": "Value #Requests" }, "properties": [{ "id": "displayName", "value": "Requests" }] },
          { "matcher": { "id": "byName", "options": "Value #Cost" }, "properties": [{ "id": "displayName", "value": "Cost (USD)" }, { "id": "unit", "value": "currencyUSD" }] },
          { "matcher": { "id": "byName", "options": "Value #AvgLatency" }, "properties": [{ "id": "displayName", "value": "Avg Latency" }, { "id": "unit", "value": "ms" }] },
          { "matcher": { "id": "byName", "options": "Value #InputTok" }, "properties": [{ "id": "displayName", "value": "Input Tokens" }] },
          { "matcher": { "id": "byName", "options": "Value #OutputTok" }, "properties": [{ "id": "displayName", "value": "Output Tokens" }] },
          { "matcher": { "id": "byName", "options": "Value #CacheTok" }, "properties": [{ "id": "displayName", "value": "Cache Read" }] }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 26 },
      "id": 8,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "Cost (USD)", "desc": true }] },
      "title": "API Request Summary by Model",
      "type": "table",
      "targets": [
        { "expr": "sum by (model) (count_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` [$__range]))", "refId": "Requests", "instant": true },
        { "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap cost_usd [$__range]))", "refId": "Cost", "instant": true },
        { "expr": "avg by (model) (avg_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap duration_ms [$__range]))", "refId": "AvgLatency", "instant": true },
        { "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap input_tokens [$__range]))", "refId": "InputTok", "instant": true },
        { "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap output_tokens [$__range]))", "refId": "OutputTok", "instant": true },
        { "expr": "sum by (model) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id` | unwrap cache_read_tokens [$__range]))", "refId": "CacheTok", "instant": true }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 26 },
      "id": 9,
      "options": { "showLabels": true, "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true, "enableLogDetails": true },
      "title": "API Request Log",
      "type": "logs",
      "targets": [{
        "expr": "{service_name=\"claude-code\"} | event_name = `api_request` | prompt_id = `$prompt_id`",
        "refId": "A"
      }]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 34 },
      "id": 104,
      "title": "All Events for this Prompt",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 35 },
      "id": 10,
      "options": { "showLabels": true, "showTime": true, "sortOrder": "Ascending", "wrapLogMessage": true, "enableLogDetails": true, "dedupStrategy": "none" },
      "title": "Complete Event Timeline",
      "type": "logs",
      "targets": [{
        "expr": "{service_name=\"claude-code\"} | prompt_id = `$prompt_id`",
        "refId": "A"
      }]
    }
  ]
}
