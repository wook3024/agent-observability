{
  "uid": "cc-prompt-analytics",
  "title": "Claude Code - Prompt List",
  "tags": ["claude-code", "prompts"],
  "timezone": "browser",
  "schemaVersion": 39,
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "links": [
    { "title": "Overview", "url": "/d/cc-overview", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "API Requests", "url": "/d/cc-api-requests", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Tool Analytics", "url": "/d/cc-tool-analytics", "type": "link", "icon": "external link", "targetBlank": false },
    { "title": "Events Explorer", "url": "/d/cc-events-explorer", "type": "link", "icon": "external link", "targetBlank": false }
  ],
  "annotations": { "list": [] },
  "templating": { "list": [] },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 101,
      "title": "Conversation History",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": { "custom": { "align": "left", "filterable": true, "inspect": true } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "event_sequence" }, "properties": [{ "id": "custom.width", "value": 50 }, { "id": "displayName", "value": "#" }] },
          { "matcher": { "id": "byName", "options": "event_timestamp" }, "properties": [{ "id": "custom.width", "value": 170 }, { "id": "displayName", "value": "Time" }] },
          { "matcher": { "id": "byName", "options": "prompt" }, "properties": [{ "id": "custom.width", "value": 500 }, { "id": "displayName", "value": "Prompt" }] },
          { "matcher": { "id": "byName", "options": "prompt_id" }, "properties": [
            { "id": "custom.width", "value": 130 },
            { "id": "displayName", "value": "Prompt ID" },
            { "id": "links", "value": [{ "title": "View Detail", "url": "/d/cc-prompt-detail?var-prompt_id=${__value.text}&${__url_time_range}", "targetBlank": false }] }
          ]}
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 1 },
      "id": 2,
      "options": { "showHeader": true, "sortBy": [{ "displayName": "#", "desc": true }], "footer": { "show": true, "reducer": ["count"], "countRows": true } },
      "title": "Prompts (click Prompt ID to drill down)",
      "type": "table",
      "targets": [{ "expr": "{service_name=\"claude-code\"} | event_name = `user_prompt`", "refId": "A" }],
      "transformations": [
        { "id": "extractFields", "options": { "source": "labels", "format": "auto" } },
        { "id": "organize", "options": {
          "excludeByName": { "Time": true, "Line": true, "id": true, "tsNs": true, "labels": true, "app_version": true, "department": true, "event_name": true, "host_arch": true, "level": true, "observed_timestamp": true, "organization_id": true, "os_type": true, "os_version": true, "scope_name": true, "scope_version": true, "service_name": true, "service_version": true, "session_id": true, "team_id": true, "terminal_type": true, "user_account_id": true, "user_account_uuid": true, "user_email": true, "user_id": true, "__error__": true, "__error_details__": true, "prompt_length": true },
          "indexByName": { "event_sequence": 0, "event_timestamp": 1, "prompt": 2, "prompt_id": 3 }
        }}
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 100,
      "title": "Prompt Cost Ranking",
      "type": "row"
    },
    {
      "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "center",
            "filterable": true,
            "inspect": true
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "prompt_id" },
            "properties": [
              { "id": "custom.width", "value": 130 },
              { "id": "displayName", "value": "Prompt ID" },
              { "id": "links", "value": [
                {
                  "title": "View Prompt Detail",
                  "url": "/d/cc-prompt-detail?var-prompt_id=${__value.text}&${__url_time_range}",
                  "targetBlank": false
                }
              ]}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Cost" },
            "properties": [
              { "id": "displayName", "value": "Total Cost (USD)" },
              { "id": "unit", "value": "currencyUSD" },
              { "id": "custom.width", "value": 130 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "transparent", "value": null },
                  { "color": "dark-yellow", "value": 0.5 },
                  { "color": "dark-orange", "value": 2 },
                  { "color": "dark-red", "value": 5 }
                ]
              }}
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #APIs" },
            "properties": [
              { "id": "displayName", "value": "API Calls" },
              { "id": "custom.width", "value": 90 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Tools" },
            "properties": [
              { "id": "displayName", "value": "Tools" },
              { "id": "custom.width", "value": 70 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #InputTok" },
            "properties": [
              { "id": "displayName", "value": "Input Tokens" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #OutputTok" },
            "properties": [
              { "id": "displayName", "value": "Output Tokens" },
              { "id": "custom.width", "value": 110 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Duration" },
            "properties": [
              { "id": "displayName", "value": "API Time" },
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #ToolDuration" },
            "properties": [
              { "id": "displayName", "value": "Tool Time" },
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #TotalDuration" },
            "properties": [
              { "id": "displayName", "value": "Total Time" },
              { "id": "unit", "value": "ms" },
              { "id": "custom.width", "value": 110 },
              { "id": "custom.cellOptions", "value": { "type": "color-background" } },
              { "id": "thresholds", "value": {
                "mode": "absolute",
                "steps": [
                  { "color": "transparent", "value": null },
                  { "color": "dark-yellow", "value": 60000 },
                  { "color": "dark-orange", "value": 300000 },
                  { "color": "dark-red", "value": 600000 }
                ]
              }}
            ]
          }
        ]
      },
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 10 },
      "id": 1,
      "options": {
        "showHeader": true,
        "sortBy": [{ "displayName": "Total Cost (USD)", "desc": true }],
        "footer": { "show": true, "reducer": ["sum"], "fields": ["Value #Cost", "Value #APIs", "Value #Tools", "Value #InputTok", "Value #OutputTok", "Value #Duration", "Value #ToolDuration", "Value #TotalDuration"] }
      },
      "title": "Click a Prompt ID to view details",
      "description": "Prompts ranked by total cost. Click Prompt ID to drill down.",
      "type": "table",
      "targets": [
        {
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap cost_usd [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "Cost",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (count_over_time({service_name=\"claude-code\"} | event_name = `api_request` [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "APIs",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (count_over_time({service_name=\"claude-code\"} | event_name = `tool_result` [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "Tools",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap input_tokens [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "InputTok",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap output_tokens [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "OutputTok",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name = `api_request` | unwrap duration_ms [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "Duration",
          "instant": true
        },
        {
          "expr": "sum by (prompt_id) (sum_over_time({service_name=\"claude-code\"} | event_name = `tool_result` | unwrap duration_ms [$__range]))",
          "legendFormat": "{{prompt_id}}",
          "refId": "ToolDuration",
          "instant": true
        },
        {
          "expr": "(max by (prompt_id) (max_over_time({service_name=\"claude-code\"} | unwrap observed_timestamp [$__range])) - min by (prompt_id) (min_over_time({service_name=\"claude-code\"} | unwrap observed_timestamp [$__range]))) / 1000000",
          "legendFormat": "{{prompt_id}}",
          "refId": "TotalDuration",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        { "id": "organize", "options": { "excludeByName": { "Time": true } } }
      ]
    }
  ]
}
