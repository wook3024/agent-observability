{
  "uid": "cc-api-requests",
  "title": "Claude Code - API Requests",
  "tags": [
    "claude-code",
    "api"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "url": "/d/cc-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "Tool Analytics",
      "url": "/d/cc-tool-analytics",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "Events Explorer",
      "url": "/d/cc-events-explorer",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    },
    {
      "title": "Prompt Analytics",
      "url": "/d/cc-prompt-analytics",
      "type": "link",
      "icon": "external link",
      "targetBlank": false,
      "keepTime": true,
      "includeVars": true
    }
  ],
  "panels": [
    {
      "type": "row",
      "title": "API Stats",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 0,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "sum(count_over_time({service_name=\"claude-code\"} | user_email=~\"$user_email\" | event_name = `api_request` [$__range]))",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": {
            "mode": "fixed",
            "fixedColor": "blue"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Avg Cost per Request",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 6,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "avg(avg_over_time({service_name=\"claude-code\"} | user_email=~\"$user_email\" | event_name = `api_request` | unwrap cost_usd [$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD",
          "color": {
            "mode": "fixed",
            "fixedColor": "green"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Avg Latency",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 12,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "avg(avg_over_time({service_name=\"claude-code\"} | user_email=~\"$user_email\" | event_name = `api_request` | unwrap duration_ms [$__range]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "color": {
            "mode": "fixed",
            "fixedColor": "yellow"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Cache Read Tokens",
      "gridPos": {
        "h": 4,
        "w": 6,
        "x": 18,
        "y": 1
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "sum(sum_over_time({service_name=\"claude-code\"} | user_email=~\"$user_email\" | event_name = `api_request` | unwrap cache_read_tokens [$__range]))",
