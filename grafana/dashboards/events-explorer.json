    "claude-code",
    "events"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "10s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "links": [
    {
      "title": "Overview",
      "url": "/d/cc-overview",
      "type": "link",
      "icon": "external link",
      "targetBlank": false
    },
    {
      "title": "API Requests",
      "url": "/d/cc-api-requests",
      "type": "link",
