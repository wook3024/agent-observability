        "h": 1,
        "w": 24,
        "x": 0,
        "y": 5
      },
      "id": 200,
      "title": "Event Distribution",
      "type": "row"
    },
    {
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 70,
            "stacking": {
              "mode": "normal"
            }
          },
          "unit": "short"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 6
      },
      "id": 6,
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "sum"
          ]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Events over Time by Type",
      "type": "timeseries",
      "targets": [
        {
          "expr": "sum by (event_name) (count_over_time({service_name=\"claude-code\"} [5m]))",
          "legendFormat": "{{event_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 14
      },
      "id": 201,
      "title": "All Events",
      "type": "row"
    },
    {
      "id": 5,
      "type": "logs",
      "title": "All Events Stream",
      "gridPos": {
        "h": 20,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "datasource": {
        "type": "loki",
        "uid": "P8E80F9AEF21F6940"
      },
      "targets": [
        {
          "expr": "{service_name=\"claude-code\"}",
          "refId": "A"
        }
      ],
      "options": {
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true,
        "enableLogDetails": true,
        "dedupStrategy": "none"
      }
    }
